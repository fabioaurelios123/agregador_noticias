# ── AI Provider ───────────────────────────────────────────────────────────────
# Escolha o provedor de IA: "anthropic", "ollama" ou "none"
# "none" usa diálogos padrão (sem IA — funciona, mas menos natural)
AI_PROVIDER=none

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Necessário quando AI_PROVIDER=anthropic
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local, gratuito) ──────────────────────────────────────────────────
# Necessário quando AI_PROVIDER=ollama
# Instale: https://ollama.com | Inicie: ollama serve
# Modelos recomendados (pull antes de usar):
#   ollama pull llama3.2        # rápido, bom para PT-BR
#   ollama pull mistral         # bom equilíbrio
#   ollama pull gemma3          # excelente em PT-BR
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── YouTube ───────────────────────────────────────────────────────────────────
# Obtenha em: YouTube Studio → Transmissões ao Vivo → Chave de stream
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx

# ── Configurações gerais ──────────────────────────────────────────────────────
DB_PATH=database/news.db
FETCH_INTERVAL_MINUTES=15
MAX_NEWS_PER_CYCLE=50
VIDEO_OUTPUT_DIR=video/output
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
